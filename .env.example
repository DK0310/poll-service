# docker-compose secrets — copy to `.env` (gitignored) and fill in real values.
# These are read via ${VAR} interpolation in docker-compose.yml. Never commit the real .env.

# SQL Server SA password (must meet complexity: upper, lower, digit, symbol, 8+ chars).
SA_PASSWORD=Your_strong_dev_password_123!

# JWT signing key — MUST be identical for gateway + identity-api; min 32 characters.
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console (APIs & Services → Credentials).
# The SAME value goes in the frontend as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Email (OTP) delivery via Gmail SMTP. SMTP_USER is the Gmail address; SMTP_PASSWORD is a
# 16-char Gmail *App Password* (requires 2-Step Verification on the account, NOT the normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=you@gmail.com
SMTP_FROM_NAME=Poll Builder
