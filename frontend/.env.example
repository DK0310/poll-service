# Frontend config — these point at the API Gateway, never an individual service.
# VITE_* vars are embedded in the client bundle (public, not secret).
# Copy to `.env` for local dev; production sets these at build time.
VITE_API_URL=http://localhost:5000/api
VITE_HUB_URL=http://localhost:5000/hubs/poll

# Google Sign-In — the SAME OAuth 2.0 Web client ID configured in the Identity API (GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
