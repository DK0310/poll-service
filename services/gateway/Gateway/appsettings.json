{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Frontend": {
    "Url": "http://localhost:5173"
  },
  "Jwt": {
    "Secret": "__SET_VIA_USER_SECRETS_OR_ENV__"
  },
  "ReverseProxy": {
    "Routes": {
      "vote-submit": {
        "ClusterId": "vote-api",
        "Match": { "Path": "/api/polls/{code}/vote" },
        "Order": 1
      },
      "vote-results": {
        "ClusterId": "vote-api",
        "Match": { "Path": "/api/polls/{code}/results" },
        "Order": 2
      },
      "vote-analytics": {
        "ClusterId": "vote-api",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/polls/{code}/analytics" },
        "Order": 8
      },
      "polls-create": {
        "ClusterId": "poll-api",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/polls", "Methods": ["POST"] },
        "Order": 10
      },
      "admin-polls": {
        "ClusterId": "poll-api",
        "AuthorizationPolicy": "admin",
        "Match": { "Path": "/api/admin/polls/{**remainder}" },
        "Order": 11
      },
      "admin-users": {
        "ClusterId": "identity-api",
        "AuthorizationPolicy": "admin",
        "Match": { "Path": "/api/admin/users/{**remainder}" },
        "Order": 12
      },
      "vote-ask": {
        "ClusterId": "vote-api",
        "Match": { "Path": "/api/polls/{code}/ask/{**remainder}" },
        "Order": 9
      },
      "signalr-hub": {
        "ClusterId": "vote-api",
        "Match": { "Path": "/hubs/{**remainder}" },
        "Order": 3
      },
      "auth-route": {
        "ClusterId": "identity-api",
        "Match": { "Path": "/api/auth/{**remainder}" },
        "Order": 4
      },
      "polls-protected": {
        "ClusterId": "poll-api",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/polls/my-polls" },
        "Order": 5
      },
      "polls-close": {
        "ClusterId": "poll-api",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/polls/{code}/close", "Methods": ["PATCH"] },
        "Order": 6
      },
      "polls-delete": {
        "ClusterId": "poll-api",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/polls/{code}", "Methods": ["DELETE"] },
        "Order": 7
      },
      "polls-public": {
        "ClusterId": "poll-api",
        "Match": { "Path": "/api/polls/{**remainder}" },
        "Order": 100
      }
    },
    "Clusters": {
      "poll-api": {
        "Destinations": {
          "default": { "Address": "http://poll-api:8080" }
        }
      },
      "vote-api": {
        "Destinations": {
          "default": { "Address": "http://vote-api:8080" }
        }
      },
      "identity-api": {
        "Destinations": {
          "default": { "Address": "http://identity-api:8080" }
        }
      }
    }
  }
}
